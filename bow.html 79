<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Global Wheel 2026</title>
    <style>
        body { display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; background-color: #2c3e50; font-family: sans-serif; overflow: hidden; }
        
        /* LOGIN SCREEN */
        #login-screen { background-color: #9b30ff; padding: 40px; border-radius: 25px; text-align: center; color: white; border: 4px solid #7b1fa2; box-shadow: 0 10px 30px rgba(0,0,0,0.5); width: 300px; }
        #login-screen input { padding: 12px; margin: 10px 0; border-radius: 8px; border: none; width: 100%; box-sizing: border-box; font-size: 16px; }
        #login-screen button { width: 100%; padding: 12px; background: #ffeb3b; border: 2px solid #333; font-weight: bold; cursor: pointer; border-radius: 8px; }

        /* GAME UI */
        .game-container { width: 360px; height: 650px; background-color: #9b30ff; border-radius: 25px; position: relative; padding: 20px; display: none; flex-direction: column; align-items: center; box-shadow: 0 15px 35px rgba(0,0,0,0.4); border: 4px solid #7b1fa2; box-sizing: border-box; }
        .winner-msg { width: 100%; height: 50px; background: white; border: 2px solid #444; display: flex; justify-content: center; align-items: center; font-weight: bold; font-size: 16px; color: #333; text-transform: uppercase; border-radius: 10px; }
        .time-circle { width: 70px; height: 70px; background: white; border-radius: 50%; display: flex; flex-direction: column; justify-content: center; align-items: center; position: absolute; top: 85px; left: 15px; border: 2px solid #555; font-weight: bold; color: #333; z-index: 5; }
        
        .wheel-container { position: relative; margin-top: 70px; }
        .arrow { position: absolute; top: -15px; left: 50%; transform: translateX(-50%); width: 0; height: 0; border-left: 15px solid transparent; border-right: 15px solid transparent; border-top: 30px solid #fff; z-index: 20; }
        
        .wheel { width: 220px; height: 220px; border-radius: 50%; border: 8px solid #fff; background: conic-gradient(#ff0000 0deg 120deg, #000000 120deg 240deg, #00ff00 240deg 360deg); transform: rotate(0deg); transition: transform 8s cubic-bezier(0.15, 0, 0.15, 1); box-shadow: 0 0 20px rgba(0,0,0,0.3); }
        
        .bet-chips-container { display: flex; gap: 8px; margin-top: 25px; }
        .chip { background: #ffeb3b; padding: 8px 12px; border-radius: 15px; font-weight: bold; font-size: 12px; cursor: pointer; border: 2px solid #333; }
        .chip.active { background: #fff; border-color: #9b30ff; transform: scale(1.1); }
        
        .options-container { display: flex; gap: 15px; margin-top: 25px; }
        .opt { width: 75px; height: 75px; border-radius: 50%; border: 3px solid #fff; cursor: pointer; display: flex; flex-direction: column; justify-content: center; align-items: center; color: white; font-size: 11px; font-weight: bold; transition: 0.2s; }
        .red-btn { background: #ff0000; } 
        .black-btn { background: #000000; } 
        .green-btn { background: #00ff00; }
        
        .bottom-controls { width: 100%; margin-top: auto; display: flex; justify-content: space-between; align-items: center; padding-bottom: 10px; }
        .balance-box { background: #ffeb3b; padding: 12px 10px; border: 2px solid #333; font-weight: bold; font-size: 13px; min-width: 140px; text-align: center; border-radius: 10px; }
        .bet-display-circle { width: 75px; height: 75px; background: #ffeb3b; border-radius: 50%; border: 3px solid #333; display: flex; flex-direction: column; justify-content: center; align-items: center; font-weight: bold; font-size: 12px; }

        /* PROFESSIONAL CUSTOM MODAL */
        #custom-modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); z-index: 100; justify-content: center; align-items: center; pointer-events: none; }
        .modal-content { background: white; padding: 20px; border-radius: 20px; text-align: center; width: 250px; box-shadow: 0 15px 40px rgba(0,0,0,0.6); animation: popIn 0.3s ease-out; border: 4px solid #ffeb3b; pointer-events: auto; }
        @keyframes popIn { from { transform: translateY(-20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        
        #modal-icon { font-size: 40px; margin-bottom: 5px; }
        .modal-content h2 { color: #9b30ff; margin: 0 0 5px; font-size: 20px; }
        .modal-content p { font-size: 14px; color: #555; margin: 0; font-weight: bold; }
    </style>
</head>
<body>

    <div id="login-screen">
        <h2>WHEEL GAME 2026</h2>
        <input type="text" id="uId" placeholder="User ID">
        <input type="password" id="uPin" placeholder="PIN">
        <button id="loginBtn" onclick="login()">LOGIN & PLAY</button>
    </div>

    <div class="game-container" id="game-ui">
        <div class="winner-msg" id="msg">WAITING...</div>
        <div class="time-circle"><span style="font-size:9px">TIME</span><span id="countdown">--</span></div>
        <div class="wheel-container"><div class="arrow"></div><div class="wheel" id="wheel"></div></div>
        
        <div class="bet-chips-container">
            <div class="chip active" onclick="setBet(10, this)">$10</div>
            <div class="chip" onclick="setBet(50, this)">$50</div>
            <div class="chip" onclick="setBet(100, this)">$100</div>
            <div class="chip" onclick="setBet(500, this)">$500</div>
        </div>
        
        <div class="options-container" id="betBtns">
            <div class="opt red-btn" onclick="placeBet('RED')">RED<br><span id="rT">$0</span></div>
            <div class="opt black-btn" onclick="placeBet('BLACK')">BLACK<br><span id="bT">$0</span></div>
            <div class="opt green-btn" onclick="placeBet('GREEN')">GREEN<br><span id="gT">$0</span></div>
        </div>
        
        <div class="bottom-controls">
            <div class="balance-box" id="bal-display">BALANCE: $0</div>
            <div class="bet-display-circle"><span style="font-size:9px">BETTING</span><span id="cur-bet-show">$10</span></div>
        </div>
    </div>

    <div id="custom-modal">
        <div class="modal-content">
            <div id="modal-icon">🏆</div>
            <h2 id="modal-title">TITLE</h2>
            <p id="modal-body">Message...</p>
        </div>
    </div>

    <script>
        // আপনার দেওয়া নতুন URL টি এখানে আপডেট করা হয়েছে
        const API_URL = "https://script.google.com/macros/s/AKfycbwkCYA5BdhlZsYoJz4ZrJ1rFtcoGph3YiUVpZpIIumgwL9gGW-FC_0uUNQF-rzZLn3-/exec";
        
        let myData = { userId: "", row: 0, balance: 0, betColors: [] };
        let selectedAmount = 10;
        let isSpinning = false;
        let currentRotation = 0;

        function showNotify(type, title, msg) {
            const modal = document.getElementById('custom-modal');
            const icon = document.getElementById('modal-icon');
            document.getElementById('modal-title').innerText = title;
            document.getElementById('modal-body').innerText = msg;
            
            if(type === 'win') icon.innerText = "💰";
            else if(type === 'error') icon.innerText = "❌";
            else if(type === 'info') icon.innerText = "ℹ️";
            else icon.innerText = "✅";

            modal.style.display = 'flex';
            setTimeout(() => { closeModal(); }, 1000); // ১ সেকেন্ড পর অটো হাইড
        }

        function closeModal() {
            document.getElementById('custom-modal').style.display = 'none';
            if(myData.row !== 0) syncData();
        }

        async function login() {
            const userId = document.getElementById('uId').value;
            const password = document.getElementById('uPin').value;
            if(!userId || !password) return showNotify('error', 'Required', 'ID and PIN needed.');
            document.getElementById('loginBtn').innerText = "CONNECTING...";
            try {
                const res = await fetch(API_URL, { method: 'POST', body: JSON.stringify({ action: "login", userId, password })});
                const data = await res.json();
                if(data.result === "success") {
                    myData.userId = userId; myData.row = data.row; myData.balance = data.balance;
                    document.getElementById('login-screen').style.display = 'none';
                    document.getElementById('game-ui').style.display = 'flex';
                    updateUI(); startGlobalTimer();
                } else { 
                    showNotify('error', 'Denied', 'Invalid ID/PIN');
                    document.getElementById('loginBtn').innerText = "LOGIN & PLAY"; 
                }
            } catch (e) { showNotify('error', 'Error', 'Connection Failed'); }
        }

        function setBet(amt, el) {
            selectedAmount = amt; document.getElementById('cur-bet-show').innerText = "$" + amt;
            document.querySelectorAll('.chip').forEach(c => c.classList.remove('active')); el.classList.add('active');
        }

        function updateUI() { document.getElementById('bal-display').innerText = "BALANCE: $" + myData.balance; }

        function startGlobalTimer() {
            setInterval(async () => {
                const sec = new Date().getSeconds();
                const cycleSec = sec % 30; 
                if (cycleSec < 15) {
                    if(isSpinning) { isSpinning = false; myData.betColors = []; }
                    document.getElementById('countdown').innerText = 15 - cycleSec;
                    document.getElementById('msg').innerText = "PLACE YOUR BETS";
                    document.getElementById('betBtns').style.pointerEvents = "auto";
                    if(cycleSec % 5 === 0) syncData();
                } else {
                    if (!isSpinning) triggerSpin();
                    document.getElementById('countdown').innerText = "GO";
                    document.getElementById('betBtns').style.pointerEvents = "none";
                }
            }, 1000);
        }

        async function syncData() {
            try {
                const res = await fetch(API_URL, { method: 'POST', body: JSON.stringify({ action: "sync", row: myData.row })});
                const d = await res.json();
                document.getElementById('rT').innerText = "$" + d.redTotal;
                document.getElementById('bT').innerText = "$" + d.blackTotal;
                document.getElementById('gT').innerText = "$" + d.greenTotal;
                myData.balance = d.balance; updateUI();
            } catch(e) {}
        }

        async function placeBet(color) {
            if (myData.betColors.length >= 2 && !myData.betColors.includes(color)) return showNotify('info', 'Limit', 'Max 2 colors.');
            if (myData.balance < selectedAmount) return showNotify('error', 'Funds', 'Low Balance.');
            try {
                const res = await fetch(API_URL, { method: 'POST', body: JSON.stringify({ action: "placeBet", row: myData.row, color: color, amount: selectedAmount })});
                const d = await res.json();
                if(d.result === "success") { 
                    if(!myData.betColors.includes(color)) myData.betColors.push(color); 
                    syncData(); 
                    showNotify('success', 'Bet Placed', '$' + selectedAmount + ' on ' + color);
                }
            } catch(e) {}
        }

        async function triggerSpin() {
            isSpinning = true;
            document.getElementById('msg').innerText = "CALCULATING...";
            try {
                const res = await fetch(API_URL, { method: 'POST', body: JSON.stringify({ action: "getWinner", row: myData.row })});
                const d = await res.json();
                const wheel = document.getElementById('wheel');
                let targetDeg = (d.winner === "RED") ? 60 : (d.winner === "BLACK") ? 180 : 300;
                let finalRotation = currentRotation + (360 * 8) + (360 - (currentRotation % 360)) - targetDeg;
                currentRotation = finalRotation;
                wheel.style.transform = `rotate(${currentRotation}deg)`;
                document.getElementById('msg').innerText = "SPINNING...";
                setTimeout(() => { 
                    document.getElementById('msg').innerText = "WINNER: " + d.winner; 
                    if(d.winAmount > 0) showNotify('win', 'WINNER!', 'You won $' + d.winAmount);
                    else setTimeout(() => syncData(), 1500);
                }, 8000); 
            } catch(e) { isSpinning = false; }
        }
    </script>
</body>
</html>
